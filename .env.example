# ============================================
# WAHA Gateway - Satu Cakrawala
# Copy this file to .env and fill in your values
# ============================================

# --- App Info ---
APP_NAME=SatuCakrawala-WAHA

# --- API Security ---
# X-Api-Key header for all API requests
WAHA_API_KEY=your-api-key-here
WAHA_API_KEY_PLAIN=your-api-key-here

# --- Dashboard ---
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=your-secure-password

# --- Swagger ---
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=your-secure-password
WHATSAPP_SWAGGER_ENABLED=true

# --- Engine ---
# NOWEB = lightweight, no browser (hemat RAM/CPU)
WAHA_DEFAULT_ENGINE=NOWEB

# --- Session Store ---
# File-based, persist to disk
WAHA_SESSION_STORE_TYPE=FILE

# --- Webhook (Global Fallback) ---
# WAHA forwards events to this backend endpoint
WHATSAPP_HOOK_URL=https://api.satucakrawala.ac.id/webhooks/waha
WHATSAPP_HOOK_EVENTS=message,message.any,session.status
