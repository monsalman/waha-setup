NODE_ENV=production
PORT=3002

# --- WAHA connection (how THIS backend reaches WAHA) ---
# dev-on-host:  http://localhost:3001
# docker:       http://satu-cakrawala-waha:3000   (set by compose)
WAHA_BASE_URL=http://localhost:3001
WAHA_API_KEY=your-waha-api-key
WAHA_SESSION=default

# --- How WAHA reaches THIS backend (used to build the session webhook URL) ---
# dev-on-host:  http://172.19.0.1:3002
# docker:       http://satu-cakrawala-backend:3002   (set by compose)
WEBHOOK_PUBLIC_URL=http://172.19.0.1:3002
WEBHOOK_SECRET=replace-with-a-long-random-string

# --- Dashboard auth ---
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=replace-with-a-strong-password
SESSION_SECRET=replace-with-a-long-random-string

# --- Agent implementation: stub | real ---
AGENT_IMPL=stub

# --- Frontend dir served at / (dashboard). Docker: /app/frontend (mounted from ../waha-control) ---
FRONTEND_DIR=/app/frontend
